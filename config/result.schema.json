{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa-cumplimiento/schemas/qe-result.schema.json",
  "title": "QA Compliance Result",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "tool",
    "category",
    "status",
    "started_at",
    "finished_at",
    "summary",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": ["e2e", "load", "dependency", "secret", "sast", "dast", "compliance", "manual"]
    },
    "surface": {
      "type": ["string", "null"],
      "enum": ["edge", "app", null]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "skipped"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "message"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skipped"]
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "metric": { "type": "string" },
          "total": { "type": "integer", "minimum": 0 },
          "pass": { "type": "integer", "minimum": 0 },
          "fail": { "type": "integer", "minimum": 0 },
          "skipped": { "type": "integer", "minimum": 0 },
          "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "avg_score": { "type": ["number", "null"] },
          "min_score": { "type": ["number", "null"] },
          "max_score": { "type": ["number", "null"] },
          "avg_latency_ms": { "type": ["number", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
