{
  "name": "cum",
  "version": "1.0.0",
  "description": "Repositorio base para construir una funcion de Quality Engineering orientada a evidencia de cumplimiento. El proyecto arranca desde Fase 0: estructura minima, escaneo de dependencias, escaneo de secretos, contrato de resultados y una imagen Docker ejecutable.",
  "private": true,
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "e2e": "playwright test",
    "e2e:auth": "node scripts/cloudflare_access_login.js",
    "e2e:install": "playwright install chromium",
    "e2e:report": "node scripts/run_e2e.js",
    "judge:review": "python3 scripts/run_judge_review.py",
    "agentic:evals": "python3 scripts/run_agentic_evals.py --rules-only",
    "agentic:evals:deepeval": "python3 scripts/run_agentic_evals.py --use-deepeval",
    "ragas:evals": "python3 scripts/run_ragas_evals.py",
    "agent:workflow:evals": "python3 scripts/run_agent_workflow_evals.py",
    "promptfoo:eval": "python3 scripts/run_promptfoo_eval.py",
    "evals:all": "python3 scripts/qa_quality_microagent.py",
    "evals:all:deepeval": "python3 scripts/qa_quality_microagent.py --use-deepeval",
    "qa:agent": "python3 scripts/qa_quality_microagent.py",
    "qa:agent:deepeval": "python3 scripts/qa_quality_microagent.py --use-deepeval",
    "start": "next start",
    "test": "npm run e2e:report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luis03David/QA_Cumplimiento.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Luis03David/QA_Cumplimiento/issues"
  },
  "homepage": "https://github.com/Luis03David/QA_Cumplimiento#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
