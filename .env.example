AITOPS_BASE_URL=https://missioncontrol.qa.aitops.ai/
AITOPS_EMAIL=
AITOPS_USER_NAME=
AITOPS_USER_EMAIL=
AITOPS_USER_PASSWORD=
AITOPS_ACCESS_CODE=
AITOPS_ACCESS_CLIENT_ID=
AITOPS_ACCESS_CLIENT_SECRET=
ENABLE_DESTRUCTIVE_TESTS=false

# CP-12 agentic evals / DeepEval judge.
# Puede reutilizar el mismo endpoint OpenAI-compatible que usa ethics_validator.
DEEPEVAL_JUDGE_BASE_URL=
DEEPEVAL_JUDGE_MODEL=
DEEPEVAL_JUDGE_API_KEY=
DEEPEVAL_JUDGE_TIMEOUT=60
DEEPEVAL_JUDGE_MAX_TOKENS=1024
DEEPEVAL_JUDGE_EXTRA_BODY=
DEEPEVAL_JUDGE_RUNPOD_POD_NAME=
DEEPEVAL_JUDGE_RUNPOD_API_KEY=
DEEPEVAL_JUDGE_RUNPOD_ENDPOINT_MODE=proxy
DEEPEVAL_JUDGE_RUNPOD_PORT=8000
DEEPEVAL_JUDGE_RUNPOD_PATH=/v1

# Aliases compatibles con ethics_validator / RunPod si prefieres duplicar ese .env.
ICS_LLM_MODE=external
ICS_LLM_API_URL=
ICS_LLM_MODEL_NAME=
ICS_LLM_API_KEY=
ICS_LLM_EXTRA_BODY=
ICS_LLM_RUNPOD_POD_NAME=
ICS_LLM_RUNPOD_API_KEY=
ICS_LLM_RUNPOD_ENDPOINT_MODE=proxy
ICS_LLM_RUNPOD_PORT=8000
ICS_LLM_RUNPOD_PATH=/v1
